{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"],
      "test/*": ["src/test/*"]
    },
    "types": ["node", "vitest/globals"]
  },
  "include": ["src/**/*.spec.ts", "vitest.config.ts", "vitest.config.e2e.ts"],
  "exclude": ["node_modules", "dist"]
}
